COMMAND VARIABLE
done

for 변수값 in 반복될값 ; do
명령...
done

for HOST in host1 host2 host3; do 
echo $HOST;
done

for user in user$(seq 1 100); do
useradd $user 
echo test | passwd --stdin $user
chage -d 0 $user
passwd -L $user
echo "$user create"
echo 
done 

