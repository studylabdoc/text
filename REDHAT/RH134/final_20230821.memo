Bash에 구현된 정규 표현식

grep  : 파일내에서 패턴을 검색하여 해당 패턴이 있는 라인의 모든 출력을 모니터로 표준출력

# grep [option] [pattern] [file]
# grep [pattern] [file]  **
# CMD | grep [pattern]  << * 
# cat file | grep text

-i  대소문자 구별없이 검색 
# cat file2 | grep -i cat
cat
concatenate
CAT
category
educated
eduCated
vindication

-w 정확한 패턴을 검색
# cat file2 | grep -w cat
cat
edu cat ed

-l 패턴이 있는 파일을 검색
port
grep -l root /etc/passwd /etc/shadow /etc/group /etc/ssh/sshd_config
/etc/passwd
/etc/shadow
/etc/group
/etc/ssh/sshd_config

하위 디렉토리 전체를 대상으로 패턴이 있는 파일을 검색?
-r
-lr : 세트로 사용
grep -lr [pattern] [디렉토리]

# grep -lr eth0 /etc
/etc/udev/rules.d/70-persistent-net.rules
/etc/NetworkManager/system-connections/Wired connection 1.nmconnection
/etc/selinux/targeted/policy/policy.33
/etc/samba/smb.conf.example

-v 패턴을 제외하고 검색
# cat file1 | grep cat
cat
concatenate
category
educated
vindication
[root@servera test]# cat file1 | grep -v cat
dog
dogma
boondoggle
chilidog

-n line번호를 같이 출력

grep 의 한계 
1 패턴을 한개만 검색이 가능.
-e 
# cat file1 | grep -e cat -e edu
cat
concatenate
category
educated
vindication

-E
# cat file1 | grep -E '(cat|edu)'
cat
concatenate
category
educated
vindication

2 특수문자 검색
정규식 문자 ^ $
 ^ : 시작하는 문자
# cat file1 | grep ^cat 
cat
category

 $ : 끝나는 문자
# cat file1 | grep cat$ 
cat

fgrep : 정규식으로 이해하지 않고 문자로만 해석
# cat file1 | fgrep dog$
dog$
[root@servera test]# cat file1 | fgrep ^cat
^cat
# cat file1 | grep -F ^cat
^cat

-A [NUMBER] 검색라인에서 추가로 아래 라인을 출력
-B [NUMBER] 검색라인에서 추가로 위 라인을 출력
-C [NUMBER] 검색라인에서 추가로 위 아래 라인을 출력
[root@servera test]# cat /etc/ssh/sshd_config | grep -B 3 -n 'Port 22'
18-# SELinux about this change.
19-# semanage port -a -t ssh_port_t -p tcp #PORTNUMBER
20-#
21:#Port 22
[root@servera test]# cat /etc/ssh/sshd_config | grep -C 3 -n 'Port 22'
18-# SELinux about this change.
19-# semanage port -a -t ssh_port_t -p tcp #PORTNUMBER
20-#
21:#Port 22
22-#AddressFamily any
23-#ListenAddress 0.0.0.0
24-#ListenAddress ::

