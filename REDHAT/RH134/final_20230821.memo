mv << X 	
cp touch << O
# dnf -y install httpd
# cd /var/www/html
[root@servera html]# touch file1
[root@servera html]# ls -lZ
total 0
-rw-r--r--. 1 root root unconfined_u:object_r:httpd_sys_content_t:s0 0 Aug 23 03:28 file1
